@model IThill_academy.Models.Course

<tr id="course-@Model.Id">
    <td>@Model.Title</td>
    <td>@Model.Description</td>
    <td>@Model.Price</td>
    <td>@Model.Duration</td>
    <td>
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" width="100" />
        }
        else
        {
            <span class="text-muted">Нет фото</span>
        }
    </td>
    <td>
        <button class="btn btn-sm btn-warning edit-course" data-id="@Model.Id">Редактировать</button>
        <button class="btn btn-sm btn-danger delete-course" data-id="@Model.Id">Удалить</button>
    </td>
</tr>