<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - IThill Admin</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Твои стили -->
    <link rel="stylesheet" href="~/css/admin.css" />
</head>

<body>

<div class="container-fluid">
    <div class="row">

        <!-- SIDEBAR -->
        <aside class="col-3 col-md-2 vh-100 p-3 bg-dark text-white">

            <h4 class="mb-4">IThill Admin</h4>

            <ul class="nav flex-column">

                <li class="nav-item mb-2">
                    <a class="nav-link text-white"
                       asp-controller="AdminMvc"
                       asp-action="Students"
                       asp-route-guid="@Guid.NewGuid()">
                        Студенты
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white"
                       asp-controller="AdminMvc"
                       asp-action="Courses"
                       asp-route-guid="@Guid.NewGuid()">
                        Курсы
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white"
                       asp-controller="AdminMvc"
                       asp-action="Enrollments"
                       asp-route-guid="@Guid.NewGuid()">
                        Записи
                    </a>
                </li>

                <li class="nav-item mt-3">
                    <form asp-controller="AccountMvc" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-light w-100">
                            Выйти
                        </button>
                    </form>
                </li>

            </ul>

        </aside>

        <!-- MAIN -->
        <main class="col-9 col-md-10 p-4">
            @RenderBody()
        </main>

    </div>
</div>

<!-- FOOTER -->
<footer class="text-center py-3 mt-4 bg-light">
    <p class="mb-0">&copy; 2026 IThill Academy — Админ-панель</p>
</footer>

<!-- jQuery (нужен для validation + модалок) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- Validation scripts -->
<partial name="_ValidationScriptsPartial" />

@RenderSection("Scripts", required: false)

</body>
</html>
