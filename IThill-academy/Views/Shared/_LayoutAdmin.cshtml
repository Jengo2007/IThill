<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Админ-панель - IThill Academy</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <!-- Боковая панель -->
        <aside class="col-3 col-md-2 vh-100 p-3 sidebar">
            <h4 class="mb-4">IThill Admin</h4>
            <ul class="nav flex-column">
                <li class="nav-item mb-2">
                    <a class="nav-link" asp-controller="AdminMvc" asp-action="Students">Студенты</a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link" asp-controller="AdminMvc" asp-action="Courses">Курсы</a>
                </li>
                <li class="nav-item mb-2">
                    <a class="nav-link" asp-controller="AdminMvc" asp-action="Enrollments">Записи</a>
                </li>
                <li class="nav-item mt-3">
                    <form asp-controller="AccountMvc" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-outline-light w-100">Выйти</button>
                    </form>
                </li>
            </ul>
        </aside>

        <!-- Основной контент -->
        <main class="col-9 col-md-10 p-4">
            @RenderBody()
        </main>
    </div>
</div>

<footer class="text-center py-3 mt-4 footer">
    <p>&copy; 2026 IThill Academy — Админ-панель</p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@RenderSection("Scripts", required: false)
</body>
</html>
