@model IEnumerable<IThill_academy.Models.Course>
@{
    ViewData["Title"] = "Курсы";
    Layout = "_Layout";
}

<h2 class="mb-4">Наши курсы</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-info">@TempData["Message"]</div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
    <tr>
        <th>Название</th>
        <th>Описание</th>
        <th>Цена</th>
        <th>Длительность</th>
        <th>Фото</th>
        <th></th>
    </tr>
    </thead>
    <tbody>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.Title</td>
            <td>@course.Description</td>
            <td>@course.Price</td>
            <td>@course.Duration</td>
            <td>
                @if (!string.IsNullOrEmpty(course.ImagePath))
                {
                    <img src="@course.ImagePath" width="120" class="img-thumbnail" />
                }
                else
                {
                    <span class="text-muted">Нет фото</span>
                }
            </td>
            <td>
                <form asp-controller="CoursesMvc" asp-action="Enroll" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="courseId" value="@course.Id" />
                    <button type="submit" class="btn btn-success">Записаться</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>